# Set this in Vercel → Settings → Environment Variables (Production + Preview)
# Must be the HTTPS URL of your deployed backend (Cloud Run, Railway, etc.)
# After setting it, trigger a new Vercel deployment (env vars are inlined at build time).
NEXT_PUBLIC_API_URL=https://your-backend-service.run.app

# Supabase (set in Vercel env vars, not committed here)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
